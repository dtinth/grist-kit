{
  "name": "grist-kit",
  "version": "0.1.2",
  "description": "Typesafe Grist JS library and CLI.",
  "keywords": [
    "cli",
    "codegen",
    "grist",
    "grist-api",
    "typescript"
  ],
  "homepage": "https://github.com/dtinth/grist-kit#readme",
  "bugs": {
    "url": "https://github.com/dtinth/grist-kit/issues"
  },
  "license": "MIT",
  "author": "Thai Pangsakulyanont <org.yi.dttvb@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dtinth/grist-kit.git"
  },
  "bin": {
    "grist-kit": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "ofetch": "^1.5.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "vite-plus": "^0.1.14"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
